{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "bundleSchemaVersion": "0.3.0",
    "source": {
      "fileKey": "3401ZFUHoboOwA6GGjAEsq",
      "fileName": "Apollo v2 (SA) - Design System",
      "scope": "Switch-subtree (node 60:450) — 37 tokens used, ~17 NEW vs Button bundle",
      "extractedAt": "2026-05-15T23:25:00Z",
      "extractor": "ds-architect@v3+switch-poc"
    },
    "modes": ["light"],
    "overlapWithButtonBundle": {
      "sharedTokens": 20,
      "uniqueToSwitch": 17,
      "$comment": "Switch reuses Button's primary/destructive/muted-foreground color palette, font-sans + medium weight, spacing 0-5/2, several width/height tokens, focus/default + focus/destructive effects, transparent + outline + destructive-alpha customs. Switch ADDS: w-8 (32), h-3 (12), border-2 (2), rounded-lg (10), font-weight/normal (400), 3 typography compounds (text-sm × leading-normal/none × medium/normal), spacing/2-5 (10), spacing/3 (12), opacity-50 (50%), base/foreground/border/ring colors, 3 custom alpha colors."
    },
    "notes": [
      "v0.3.0 PoC capture. Values resolved (alias chains not preserved by get_variable_defs).",
      "Standalone tokens.json for the Switch bundle — overlap with Button is duplicated per-bundle-self-contained design. Consolidation into a shared apollo-v2-tokens.json deferred to atom-batch phase."
    ]
  },

  "color": {
    "base": {
      "primary": {
        "$value": "#5a35c0",
        "$type": "color",
        "$description": "Primary action / active toggle track color (when Active=On).",
        "$extensions": { "intent": "primary-action-default", "shadcn": "primary", "tailwind": "bg-primary", "figma": { "name": "base/primary" } }
      },
      "destructive": {
        "$value": "#dc2626",
        "$type": "color",
        "$description": "Destructive — used by Switch Invalid state.",
        "$extensions": { "intent": "destructive-action-default", "shadcn": "destructive", "figma": { "name": "base/destructive" } }
      },
      "background": {
        "$value": "#fafafa",
        "$type": "color",
        "$description": "Page background. Used as Switch thumb fill (light contrast against the track).",
        "$extensions": { "intent": "background", "shadcn": "background", "figma": { "name": "base/background" } }
      },
      "foreground": {
        "$value": "#0a0a0a",
        "$type": "color",
        "$description": "Primary foreground text color. Switch label color in Default state.",
        "$extensions": { "intent": "foreground", "shadcn": "foreground", "figma": { "name": "base/foreground" }, "sourceTrace": "NEW in Switch PoC vs Button bundle." }
      },
      "muted-foreground": {
        "$value": "#737373",
        "$type": "color",
        "$description": "Muted/secondary text. Switch helper text + Disabled label.",
        "$extensions": { "intent": "muted-foreground", "shadcn": "muted-foreground", "figma": { "name": "base/muted-foreground" } }
      },
      "border": {
        "$value": "#e5e5e5",
        "$type": "color",
        "$description": "Default border color. Switch Box-type frame border.",
        "$extensions": { "intent": "border", "shadcn": "border", "figma": { "name": "base/border" }, "sourceTrace": "NEW in Switch PoC vs Button bundle." }
      },
      "ring": {
        "$value": "#5a35c0",
        "$type": "color",
        "$description": "Focus ring base color. Same hex as base/primary but semantically distinct — used specifically for focus indicators.",
        "$extensions": { "intent": "focus-ring-base", "shadcn": "ring", "tailwind": "ring-primary", "figma": { "name": "base/ring" }, "sourceTrace": "NEW in Switch PoC vs Button bundle." }
      }
    },

    "custom": {
      "outline": {
        "$value": "#a3a3a380",
        "$type": "color",
        "$description": "Focus ring color (neutral-gray with 50% alpha).",
        "$extensions": { "intent": "focus-ring", "alpha": 0.5, "figma": { "name": "custom/outline" } }
      },
      "destructive-10-dark-20": {
        "$value": "#dc26261a",
        "$type": "color",
        "$description": "Destructive @ 10% alpha (dark: 20%). Switch Invalid state subtle background.",
        "$extensions": { "intent": "destructive-alpha-10", "alpha": 0.10, "figma": { "name": "custom/destructive\\10 dark:destructive\\20" } }
      },
      "destructive-20-dark-40": {
        "$value": "#dc262633",
        "$type": "color",
        "$description": "Destructive @ 20% alpha (dark: 40%). Switch Invalid focus ring spread color.",
        "$extensions": { "intent": "destructive-alpha-20", "alpha": 0.20, "figma": { "name": "custom/destructive\\20 dark:destructive\\40" } }
      },
      "input-dark-input-80": {
        "$value": "#a3a3a3",
        "$type": "color",
        "$description": "Input/track-Off color (dark mode: input @ 80%). Switch track fill when Active=Off.",
        "$extensions": { "intent": "input-track-off", "figma": { "name": "custom/input dark:input\\80" }, "sourceTrace": "NEW in Switch PoC vs Button bundle." }
      },
      "bg-primary-5-dark-bg-primary-10": {
        "$value": "#1717170d",
        "$type": "color",
        "$description": "Primary @ 5% alpha (dark: 10%). Subtle disabled-state overlay or hover-state translucent fill.",
        "$extensions": { "intent": "primary-alpha-5", "alpha": 0.05, "figma": { "name": "custom/bg-primary\\5 dark:bg-primary\\10" }, "sourceTrace": "NEW in Switch PoC vs Button bundle." }
      },
      "alpha-30-dark-alpha-20": {
        "$value": "#ffffffb2",
        "$type": "color",
        "$description": "White @ 70% alpha (dark: 20%). Per Apollo v2 naming, alpha-30 in light context, alpha-20 in dark.",
        "$extensions": { "intent": "white-alpha-70", "alpha": 0.70, "figma": { "name": "custom/alpha-30 dark:alpha-20" }, "sourceTrace": "NEW in Switch PoC vs Button bundle." }
      }
    },

    "tailwind": {
      "base": {
        "transparent": {
          "$value": "#ffffff00",
          "$type": "color",
          "$description": "Fully transparent.",
          "$extensions": { "intent": "transparent", "alpha": 0, "tailwind": "transparent", "figma": { "name": "tailwind colors/base/transparent" } }
        }
      }
    }
  },

  "spacing": {
    "0-5": { "$value": "2px",  "$type": "dimension", "$extensions": { "tailwind": "p-0.5", "figma": { "name": "spacing/0-5" } } },
    "2":   { "$value": "8px",  "$type": "dimension", "$extensions": { "tailwind": "p-2",   "figma": { "name": "spacing/2" } } },
    "2-5": { "$value": "10px", "$type": "dimension", "$description": "10px spacing — Switch label-to-track gap.", "$extensions": { "tailwind": "p-2.5", "figma": { "name": "spacing/2-5" }, "sourceTrace": "NEW in Switch PoC vs Button bundle." } },
    "3":   { "$value": "12px", "$type": "dimension", "$description": "12px spacing — Switch Box-type internal padding.", "$extensions": { "tailwind": "p-3", "figma": { "name": "spacing/3" }, "sourceTrace": "NEW in Switch PoC vs Button bundle." } }
  },

  "height": {
    "h-3": { "$value": "12px", "$type": "dimension", "$description": "12px height — Switch sm thumb diameter.", "$extensions": { "tailwind": "h-3", "figma": { "name": "height/h-3" }, "sourceTrace": "NEW in Switch PoC vs Button bundle." } },
    "h-4": { "$value": "16px", "$type": "dimension", "$description": "16px height — Switch default thumb diameter.", "$extensions": { "tailwind": "h-4", "figma": { "name": "height/h-4" } } }
  },

  "width": {
    "w-3": { "$value": "12px", "$type": "dimension", "$extensions": { "tailwind": "w-3", "figma": { "name": "width/w-3" } } },
    "w-4": { "$value": "16px", "$type": "dimension", "$extensions": { "tailwind": "w-4", "figma": { "name": "width/w-4" } } },
    "w-6": { "$value": "24px", "$type": "dimension", "$description": "24px width — Switch sm track length.", "$extensions": { "tailwind": "w-6", "figma": { "name": "width/w-6" } } },
    "w-8": { "$value": "32px", "$type": "dimension", "$description": "32px width — Switch default track length.", "$extensions": { "tailwind": "w-8", "figma": { "name": "width/w-8" }, "sourceTrace": "NEW in Switch PoC vs Button bundle." } }
  },

  "border-radius": {
    "rounded-full": {
      "$value": "9999px",
      "$type": "dimension",
      "$description": "Fully rounded / pill. Switch track + thumb.",
      "$extensions": { "intent": "full-radius", "shadcn": "rounded-full", "tailwind": "rounded-full", "figma": { "name": "border-radius/rounded-full" } }
    },
    "rounded-lg": {
      "$value": "10px",
      "$type": "dimension",
      "$description": "Large rounded corner — Switch Box-type frame.",
      "$extensions": { "intent": "lg-radius", "shadcn": "rounded-lg", "tailwind": "rounded-lg", "figma": { "name": "border-radius/rounded-lg" }, "sourceTrace": "NEW in Switch PoC vs Button bundle." }
    }
  },

  "border-width": {
    "border":   { "$value": "1px", "$type": "dimension", "$description": "Default border weight (Switch Box-type frame).", "$extensions": { "tailwind": "border", "figma": { "name": "border-width/border" } } },
    "border-2": { "$value": "2px", "$type": "dimension", "$description": "Thicker border weight (Switch Focus state).", "$extensions": { "tailwind": "border-2", "figma": { "name": "border-width/border-2" }, "sourceTrace": "NEW in Switch PoC vs Button bundle." } }
  },

  "opacity": {
    "opacity-50": {
      "$value": 0.5,
      "$type": "number",
      "$description": "50% opacity — Switch Disabled state visual cue.",
      "$extensions": { "tailwind": "opacity-50", "figma": { "name": "opacity/opacity-50", "rawValue": "50" }, "sourceTrace": "NEW in Switch PoC vs Button bundle. Note: Button bundle's disabled-treatment uses tinted color, not opacity reduction. Switch uses opacity. Inconsistency across the DS — audit candidate." }
    }
  },

  "font": {
    "font-sans": {
      "$value": "Open Sans",
      "$type": "fontFamily",
      "$description": "Primary sans-serif family.",
      "$extensions": { "tailwind": "font-sans", "figma": { "name": "font/font-sans" } }
    }
  },

  "font-weight": {
    "normal": {
      "$value": 400,
      "$type": "fontWeight",
      "$description": "Normal/regular weight — Switch helper text.",
      "$extensions": { "tailwind": "font-normal", "figma": { "name": "font-weight/normal" }, "sourceTrace": "NEW in Switch PoC vs Button bundle." }
    },
    "medium": {
      "$value": 500,
      "$type": "fontWeight",
      "$description": "Medium weight — Switch label text.",
      "$extensions": { "tailwind": "font-medium", "figma": { "name": "font-weight/medium" } }
    }
  },

  "text": {
    "sm": {
      "font-size":   { "$value": "14px", "$type": "dimension",  "$extensions": { "tailwind": "text-sm", "figma": { "name": "text/sm/font-size" } } },
      "line-height": { "$value": "20px", "$type": "dimension",  "$extensions": { "figma": { "name": "text/sm/line-height" } } }
    }
  },

  "typography": {
    "text-sm-leading-normal-medium": {
      "$value": {
        "fontFamily":   "{font.font-sans}",
        "fontWeight":   "{font-weight.medium}",
        "fontSize":     "{text.sm.font-size}",
        "lineHeight":   "{text.sm.line-height}",
        "letterSpacing": "0px"
      },
      "$type": "typography",
      "$description": "Body sm medium — Switch label.",
      "$extensions": { "figma": { "name": "text-sm/leading-normal/medium" }, "sourceTrace": "NEW in Switch PoC vs Button bundle." }
    },
    "text-sm-leading-normal-normal": {
      "$value": {
        "fontFamily":   "{font.font-sans}",
        "fontWeight":   "{font-weight.normal}",
        "fontSize":     "{text.sm.font-size}",
        "lineHeight":   "{text.sm.line-height}",
        "letterSpacing": "0px"
      },
      "$type": "typography",
      "$description": "Body sm normal — Switch helper text.",
      "$extensions": { "figma": { "name": "text-sm/leading-normal/normal" }, "sourceTrace": "NEW in Switch PoC vs Button bundle." }
    },
    "text-sm-leading-none-medium": {
      "$value": {
        "fontFamily":   "{font.font-sans}",
        "fontWeight":   "{font-weight.medium}",
        "fontSize":     "{text.sm.font-size}",
        "lineHeight":   "1",
        "letterSpacing": "0px"
      },
      "$type": "typography",
      "$description": "Body sm medium with line-height: 1 — tight Switch contexts.",
      "$extensions": { "figma": { "name": "text-sm/leading-none/medium" }, "sourceTrace": "NEW in Switch PoC vs Button bundle. line-height = 1 (font-size, not a px token)." }
    }
  },

  "effect": {
    "focus-default": {
      "$value": {
        "color":   "{color.custom.outline}",
        "offsetX": "0px", "offsetY": "0px",
        "blur":    "0px", "spread":  "3px",
        "type":    "dropShadow", "inset":  false
      },
      "$type": "shadow",
      "$description": "Focus ring — 3px outset drop-shadow at 50% alpha. Switch Focus state on non-Invalid cells.",
      "$extensions": { "intent": "focus-ring", "figma": { "name": "focus/default" }, "css": "box-shadow: 0 0 0 3px rgba(163, 163, 163, 0.5)" }
    },
    "focus-destructive": {
      "$value": {
        "color":   "{color.custom.destructive-20-dark-40}",
        "offsetX": "0px", "offsetY": "0px",
        "blur":    "0px", "spread":  "3px",
        "type":    "dropShadow", "inset":  false
      },
      "$type": "shadow",
      "$description": "Focus ring — destructive variant. Switch Focus + Invalid combined.",
      "$extensions": { "intent": "focus-ring-destructive", "figma": { "name": "focus/destructive" }, "css": "box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.2)" }
    }
  }
}
