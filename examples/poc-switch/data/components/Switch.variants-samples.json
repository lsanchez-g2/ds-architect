  "$verificationCandidate": {
    "$comment": "These 3 cells double as smoke-test inputs for the next Claude Design re-test. Feed this file + tokens.json + Switch.component.json; ask Claude Design to render each cell.",
    "expectations": [
      {
        "cell": "size=default,active=Off,state=Default,type=Default,controlPlacement=Start",
        "expectCSS": [
          "container: display: inline-flex; gap: 8px; width: 312px",
          "track: background-color: #a3a3a3; border: 2px solid transparent; border-radius: 9999px; height: 18.4px; width: 32px; justify-content: flex-start",
          "thumb: background-color: #fafafa; border-radius: 9999px; width: 16px; height: 16px",
          "label: color: #0a0a0a; font-family: Open Sans; font-weight: 500; font-size: 14px; line-height: 20px",
          "description: color: #737373; font-weight: 400"
        ],
        "expectVisual": "Gray pill track 32×~18 with white 16px thumb at LEFT. Black label 'Switch Text' + gray description below."
      },
      {
        "cell": "size=default,active=On,state=Default,type=Default,controlPlacement=Start",
        "expectCSS": [
          "track: background-color: #5a35c0 (violet primary); justify-content: flex-end",
          "thumb: same 16px white circle, now at RIGHT edge of track",
          "label + description: unchanged from Active=Off cell"
        ],
        "expectVisual": "Violet pill track with white thumb at RIGHT."
      },
      {
        "cell": "size=default,active=Off,state=Invalid,type=Default,controlPlacement=Start",
        "expectCSS": [
          "track: background-color: #a3a3a3; border: 1px solid #dc2626; box-shadow: 0 0 0 3px rgba(220,38,38,0.2); overflow: hidden",
          "label: color: #dc2626 (destructive)",
          "description: color: #737373 (muted — UNCHANGED, F11 documents this)"
        ],
        "expectVisual": "Gray pill track with thin red border + red glow ring at rest, red label, muted gray description. No Focus required to show the ring."
      }
